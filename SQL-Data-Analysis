<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sales Dashboard</title>
  <style>
    body { margin: 0; padding: 1.5rem; font-family: system-ui, sans-serif; background: #f5f5f3; color: #1a1a18; }
    .dash { max-width: 900px; margin: 0 auto; }
    h1 { font-size: 20px; font-weight: 500; margin: 0 0 1.5rem; }
    .metric-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 1.75rem; }
    .metric { background: #ebebea; border-radius: 8px; padding: 1rem; }
    .metric-label { font-size: 13px; color: #6b6b69; margin: 0 0 4px; }
    .metric-value { font-size: 22px; font-weight: 500; color: #1a1a18; margin: 0; }
    .tab-row { display: flex; gap: 0; margin-bottom: 1.25rem; border-bottom: 1px solid rgba(0,0,0,0.1); }
    .tab { padding: 8px 16px; font-size: 13px; cursor: pointer; border: none; background: transparent; color: #6b6b69; border-bottom: 2px solid transparent; margin-bottom: -1px; }
    .tab.active { color: #1a1a18; border-bottom: 2px solid #1a1a18; font-weight: 500; }
    .legend { display: flex; flex-wrap: wrap; gap: 14px; margin-bottom: 8px; font-size: 12px; color: #6b6b69; }
    .legend span { display: flex; align-items: center; gap: 5px; }
    .leg-sq { width: 10px; height: 10px; border-radius: 2px; display: inline-block; }
    .chart-wrap { position: relative; width: 100%; }
  </style>
</head>
<body>
<div class="dash">
  <h1>Sales Dashboard</h1>

  <div class="metric-grid">
    <div class="metric">
      <p class="metric-label">Total revenue</p>
      <p class="metric-value" id="m-rev">£0</p>
    </div>
    <div class="metric">
      <p class="metric-label">Countries</p>
      <p class="metric-value" id="m-cty">0</p>
    </div>
    <div class="metric">
      <p class="metric-label">Top product</p>
      <p class="metric-value" style="font-size:15px" id="m-top">—</p>
    </div>
    <div class="metric">
      <p class="metric-label">Peak month</p>
      <p class="metric-value" style="font-size:15px" id="m-peak">—</p>
    </div>
  </div>

  <div class="tab-row">
    <button class="tab active" onclick="showTab('monthly')">Monthly sales</button>
    <button class="tab" onclick="showTab('products')">Top products</button>
    <button class="tab" onclick="showTab('country')">By country</button>
  </div>

  <div id="tab-monthly">
    <div class="legend"><span><span class="leg-sq" style="background:#3266ad"></span>Revenue</span></div>
    <div class="chart-wrap" style="height:280px"><canvas id="chartMonthly"></canvas></div>
  </div>
  <div id="tab-products" style="display:none">
    <div class="legend"><span><span class="leg-sq" style="background:#0f6e56"></span>Units sold</span></div>
    <div class="chart-wrap" id="products-wrap"><canvas id="chartProducts"></canvas></div>
  </div>
  <div id="tab-country" style="display:none">
    <div class="legend"><span><span class="leg-sq" style="background:#853a0b"></span>Revenue</span></div>
    <div class="chart-wrap" id="country-wrap"><canvas id="chartCountry"></canvas></div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
/* =============================================
   REPLACE THE DATA BELOW WITH YOUR REAL DATA
   ============================================= */

const monthly = [
  {m:'Nov 2010',r:55220},{m:'Dec 2010',r:96760},{m:'Jan 2011',r:68400},{m:'Feb 2011',r:75300},
  {m:'Mar 2011',r:80100},{m:'Apr 2011',r:77500},{m:'May 2011',r:82000},{m:'Jun 2011',r:85400},
  {m:'Jul 2011',r:71200},{m:'Aug 2011',r:76600},{m:'Sep 2011',r:99300},{m:'Oct 2011',r:118700},
  {m:'Nov 2011',r:102400},{m:'Dec 2011',r:138400}
];

const products = [
  {d:'PAPER CRAFT LITTLE BIRDIE',q:80995},{d:'MEDIUM CERAMIC TOP STORAGE JAR',q:77916},
  {d:'WORLD WAR 2 GLIDERS ASSTD DESIGNS',q:54415},{d:'JUMBO BAG RED RETROSPOT',q:47132},
  {d:'WHITE HANGING HEART T-LIGHT HOLDER',q:36612},{d:'PACK OF 72 RETROSPOT CAKE CASES',q:36039},
  {d:'ASSORTED COLOUR BIRD ORNAMENT',q:35314},{d:'RABBIT NIGHT LIGHT',q:30680},
  {d:'MINI PAINT SET VINTAGE',q:26437},{d:'HAND WARMER UNION JACK',q:23502}
];

const countries = [
  {c:'United Kingdom',r:8187806},{c:'Netherlands',r:284661},{c:'EIRE',r:263277},
  {c:'Germany',r:221698},{c:'France',r:197403},{c:'Australia',r:137511},
  {c:'Switzerland',r:56385},{c:'Spain',r:54774},{c:'Belgium',r:40910},{c:'Sweden',r:36596}
];

/* ============================================= */

const totalRev = monthly.reduce((s,x) => s + x.r, 0);
document.getElementById('m-rev').textContent = '£' + Math.round(totalRev).toLocaleString();
document.getElementById('m-cty').textContent = countries.length + '+';
document.getElementById('m-top').textContent = products[0].d.split(' ').slice(0,3).join(' ') + '…';
const peak = monthly.reduce((a,b) => b.r > a.r ? b : a);
document.getElementById('m-peak').textContent = peak.m;

const shared = { responsive:true, maintainAspectRatio:false, plugins:{ legend:{ display:false } } };
function fmtGBP(v){ return '£' + (v >= 1e6 ? (v/1e6).toFixed(1)+'M' : v >= 1e3 ? (v/1e3).toFixed(0)+'K' : v); }

new Chart(document.getElementById('chartMonthly'), {
  type: 'bar',
  data: { labels: monthly.map(x => x.m), datasets: [{ label:'Revenue', data: monthly.map(x => x.r), backgroundColor:'#3266ad', borderRadius:3 }] },
  options: { ...shared, scales: {
    x: { ticks:{ autoSkip:false, maxRotation:45, font:{size:11} }, grid:{display:false} },
    y: { ticks:{ callback:fmtGBP, font:{size:11} }, grid:{color:'rgba(0,0,0,0.07)'} }
  }}
});

document.getElementById('products-wrap').style.height = (products.length * 42 + 80) + 'px';
new Chart(document.getElementById('chartProducts'), {
  type: 'bar',
  data: { labels: products.map(x => x.d.split(' ').slice(0,4).join(' ')), datasets: [{ label:'Units sold', data: products.map(x => x.q), backgroundColor:'#0f6e56', borderRadius:3 }] },
  options: { ...shared, indexAxis:'y', scales: {
    x: { ticks:{ callback: v => v >= 1000 ? (v/1000).toFixed(0)+'K' : v, font:{size:11} }, grid:{color:'rgba(0,0,0,0.07)'} },
    y: { ticks:{ font:{size:11} }, grid:{display:false} }
  }}
});

document.getElementById('country-wrap').style.height = (countries.length * 42 + 80) + 'px';
new Chart(document.getElementById('chartCountry'), {
  type: 'bar',
  data: { labels: countries.map(x => x.c), datasets: [{ label:'Revenue', data: countries.map(x => x.r), backgroundColor:'#853a0b', borderRadius:3 }] },
  options: { ...shared, indexAxis:'y', scales: {
    x: { ticks:{ callback:fmtGBP, font:{size:11} }, grid:{color:'rgba(0,0,0,0.07)'} },
    y: { ticks:{ font:{size:11} }, grid:{display:false} }
  }}
});

function showTab(name) {
  ['monthly','products','country'].forEach((t, i) => {
    document.getElementById('tab-'+t).style.display = t === name ? '' : 'none';
    document.querySelectorAll('.tab')[i].classList.toggle('active', t === name);
  });
}
</script>
</body>
</html>
